// ═══════════════════════════════════════════════════════════════
//  STATE
// ═══════════════════════════════════════════════════════════════
let currentTopic = 0;
let currentQuestion = 0;
let answers = []; // per topic: array of null or {selected, correct}
let topicAnswers = [];

function initAnswers() {
  topicAnswers = topics.map(t => new Array(t.questions.length).fill(null));
}

function switchTopic(idx) {
  currentTopic = idx;
  currentQuestion = 0;
  document.querySelectorAll('.topic-btn').forEach((b, i) => {
    b.classList.toggle('active', i === idx);
  });
  document.getElementById('resultsPanel').classList.remove('show');
  document.getElementById('quizArea').style.display = '';
  document.getElementById('controls').style.display = '';
  document.getElementById('qNavPanel').style.display = '';
  renderQuestion();
}

function renderQuestion() {
  const topic = topics[currentTopic];
  const q = topic.questions[currentQuestion];
  const saved = topicAnswers[currentTopic][currentQuestion];
  const total = topic.questions.length;
  const answered = topicAnswers[currentTopic].filter(a => a !== null).length;

  // Progress
  document.getElementById('progressFraction').textContent = `${answered} / ${total}`;
  document.getElementById('progressFill').style.width = `${(answered / total) * 100}%`;

  // Header score
  const correct = topicAnswers[currentTopic].filter(a => a !== null && a.correct).length;
  document.getElementById('headerScore').textContent = `Score: ${correct} / ${answered}`;

  // Question HTML
  const diffClass = { basic: 'diff-basic', intermediate: 'diff-intermediate', advanced: 'diff-advanced' };
  const diffLabel = { basic: 'Foundational', intermediate: 'Intermediate', advanced: 'Advanced' };
  const letters = ['A', 'B', 'C', 'D'];

  let optsHtml = q.opts.map((opt, i) => {
    let cls = 'opt-btn';
    if (saved !== null) {
      if (i === q.ans) cls += ' correct';
      else if (i === saved.selected && !saved.correct) cls += ' wrong';
    }
    return `<button class="${cls}" ${saved !== null ? 'disabled' : ''} onclick="selectAnswer(${i})">
      <span class="opt-letter">${letters[i]}</span>
      <span>${opt}</span>
    </button>`;
  }).join('');

  let feedbackHtml = '';
  if (saved !== null) {
    const cls = saved.correct ? 'feedback correct-fb show' : 'feedback wrong-fb show';
    const label = saved.correct ? '✓ Correct' : '✗ Incorrect';
    feedbackHtml = `<div class="${cls}">
      <strong>${label}</strong>
      ${q.expl}
      <button class="ai-btn" onclick="askAI(${currentQuestion})" id="aiBtn${currentQuestion}">🤖 Ask Claude for deeper explanation</button>
      <div class="ai-explain-box" id="aiBox${currentQuestion}"></div>
    </div>`;
  }

  document.getElementById('quizArea').innerHTML = `
    <div class="q-card">
      <div class="q-meta">
        <span class="q-number">Question ${currentQuestion + 1} of ${total}</span>
        <span class="q-difficulty ${diffClass[q.diff] || 'diff-basic'}">${diffLabel[q.diff] || 'Foundational'}</span>
      </div>
      <div class="q-text">${q.q}</div>
      <div class="options">${optsHtml}</div>
      ${feedbackHtml}
    </div>`;

  // Controls
  const nextBtn = document.getElementById('nextBtn');
  const finishBtn = document.getElementById('finishBtn');
  const restartBtn = document.getElementById('restartBtn');
  nextBtn.disabled = saved === null;
  nextBtn.style.display = '';
  finishBtn.style.display = answered === total ? '' : 'none';
  restartBtn.style.display = 'none';

  // Nav grid
  renderNavGrid();
}

function renderNavGrid() {
  const topic = topics[currentTopic];
  const grid = document.getElementById('qNavGrid');
  grid.innerHTML = topic.questions.map((_, i) => {
    const saved = topicAnswers[currentTopic][i];
    let cls = 'q-dot';
    if (i === currentQuestion) cls += ' current';
    else if (saved !== null && saved.correct) cls += ' answered-correct';
    else if (saved !== null && !saved.correct) cls += ' answered-wrong';
    return `<button class="${cls}" onclick="jumpTo(${i})">${i + 1}</button>`;
  }).join('');
}

function jumpTo(idx) {
  currentQuestion = idx;
  renderQuestion();
}

function selectAnswer(selected) {
  const q = topics[currentTopic].questions[currentQuestion];
  const correct = selected === q.ans;
  topicAnswers[currentTopic][currentQuestion] = { selected, correct };
  renderQuestion();
}

function nextQuestion() {
  const total = topics[currentTopic].questions.length;
  if (currentQuestion < total - 1) {
    currentQuestion++;
    renderQuestion();
  }
}

function prevQuestion() {
  if (currentQuestion > 0) {
    currentQuestion--;
    renderQuestion();
  }
}

function showResults() {
  const topic = topics[currentTopic];
  const answers = topicAnswers[currentTopic];
  const correct = answers.filter(a => a !== null && a.correct).length;
  const total = topic.questions.length;
  const pct = Math.round((correct / total) * 100);

  let grade, msg;
  if (pct >= 90) { grade = 'A+'; msg = 'Outstanding performance. You have a thorough command of this material — excellent exam preparation.'; }
  else if (pct >= 80) { grade = 'A'; msg = 'Strong performance. You demonstrate solid understanding of the key concepts.'; }
  else if (pct >= 70) { grade = 'B'; msg = 'Good effort. Review the questions you missed to strengthen your weaker areas.'; }
  else if (pct >= 60) { grade = 'C'; msg = 'Satisfactory, but there is room for improvement. Focus on the concepts behind incorrect answers.'; }
  else { grade = 'D'; msg = 'You need more review of this topic. Re-read the material and retake the quiz.'; }

  document.getElementById('quizArea').style.display = 'none';
  document.getElementById('controls').style.display = 'none';
  document.getElementById('qNavPanel').style.display = 'none';

  const panel = document.getElementById('resultsPanel');
  panel.innerHTML = `
    <div class="results-grade">${grade}</div>
    <div class="results-pct">${pct}% — ${correct} out of ${total} correct</div>
    <div class="results-stats">
      <div class="stat-item">
        <div class="stat-num" style="color:var(--green)">${correct}</div>
        <div class="stat-label">Correct</div>
      </div>
      <div class="stat-item">
        <div class="stat-num" style="color:var(--red)">${total - correct}</div>
        <div class="stat-label">Incorrect</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">${total}</div>
        <div class="stat-label">Total</div>
      </div>
    </div>
    <div class="results-msg">${msg}</div>
    <button class="btn btn-primary" onclick="restartTopic()">Retake This Topic</button>
  `;
  panel.classList.add('show');
  document.getElementById('progressFill').style.width = `${pct}%`;
  document.getElementById('progressFraction').textContent = `${total} / ${total}`;
}

function restartTopic() {
  topicAnswers[currentTopic] = new Array(topics[currentTopic].questions.length).fill(null);
  currentQuestion = 0;
  document.getElementById('resultsPanel').classList.remove('show');
  document.getElementById('quizArea').style.display = '';
  document.getElementById('controls').style.display = '';
  document.getElementById('qNavPanel').style.display = '';
  renderQuestion();
}

// ═══════════════════════════════════════════════════════════════
//  AI EXPLANATION via Anthropic API
// ═══════════════════════════════════════════════════════════════
async function askAI(qIdx) {
  const btn = document.getElementById(`aiBtn${qIdx}`);
  const box = document.getElementById(`aiBox${qIdx}`);
  if (!btn || !box) return;

  const topic = topics[currentTopic];
  const q = topic.questions[qIdx];
  const letters = ['A', 'B', 'C', 'D'];

  btn.disabled = true;
  btn.textContent = 'Loading...';
  box.classList.add('show');
  box.innerHTML = `<div class="ai-loading"><div class="spinner"></div> Claude is preparing a detailed explanation...</div>`;

  const prompt = `You are a banking and finance professor explaining a concept to a bachelor's degree student studying Banking & Finance.

The student answered a multiple-choice exam question. Please provide a clear, thorough explanation (3-5 sentences) covering:
1. Why the correct answer is right
2. The key underlying concept
3. A brief note on why any common wrong answers are incorrect

Question: ${q.q}

Options:
${q.opts.map((o, i) => `${letters[i]}) ${o}`).join('\n')}

Correct Answer: ${letters[q.ans]}) ${q.opts[q.ans]}

Brief explanation already given: ${q.expl}

Please expand on this with deeper academic insight relevant to banking and finance studies. Keep your response clear and educational, using plain language.`;

  try {
    const response = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        model: "claude-sonnet-4-20250514",
        max_tokens: 1000,
        messages: [{ role: "user", content: prompt }]
      })
    });

    const data = await response.json();
    const text = data.content?.map(c => c.text || '').join('') || 'No explanation available.';
    box.innerHTML = `<strong style="font-family:'IBM Plex Mono',monospace;font-size:0.68rem;color:var(--gold);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:8px;">Claude's Explanation</strong>${text.replace(/\n/g, '<br>')}`;
    btn.textContent = '🤖 Explanation loaded';
  } catch (err) {
    box.innerHTML = `<em style="color:var(--gray)">Could not load explanation. Please check your connection and try again.</em>`;
    btn.textContent = '🤖 Try again';
    btn.disabled = false;
  }
}

// ── Init ──
initAnswers();
renderQuestion();
</script>
